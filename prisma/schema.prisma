datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                     String                  @id @default(uuid())
  name                   String?
  email                  String                  @unique
  emailVerified          DateTime?
  image                  String?
  points                 Int                     @default(0)
  streak                 Int                     @default(0)
  misses                 Int                     @default(0)
  passwordHash           String?
  adminRole              String                  @default("none")
  accountStatus          String                  @default("active")
  suspendedUntil         DateTime?
  moderationReason       String?
  predictions            Prediction[]
  accounts               Account[]
  sessions               Session[]
  leaguesOwned           League[]                @relation("LeagueOwner")
  leaguesJoined          LeagueMember[]
  leagueJoinRequests     LeagueJoinRequest[]
  leaguePointEntries     LeaguePointEntry[]
  leagueRankingSnapshots LeagueRankingSnapshot[]
  resetRequests          PasswordResetRequest[]
  resetReviews           PasswordResetRequest[]   @relation("PasswordResetReviewer")
  adminAuditLogs         AdminAuditLog[]          @relation("AdminAuditActor")
  createdAt              DateTime                @default(now())

  @@index([adminRole])
  @@index([accountStatus])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  revokedAt    DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
}

model Match {
  id                 String             @id @default(uuid())
  externalId         Int?               @unique
  homeTeam           String
  awayTeam           String
  homeFlag           String?
  awayFlag           String?
  homeTeamLogo       String?
  awayTeamLogo       String?
  homeLabel          String?
  awayLabel          String?
  kickOff            DateTime
  homeScore          Int?
  awayScore          Int?
  status             String             @default("scheduled")
  stage              String             @default("group")
  group              String?
  matchday           String?
  elapsed            String?            @default("notstarted")
  lastSyncAt         DateTime?
  predictions        Prediction[]
  lineup             MatchLineup?
  leaguePointEntries LeaguePointEntry[]

  @@index([stage, kickOff])
  @@index([group, kickOff])
  @@index([matchday, kickOff])
}

model Prediction {
  id         String            @id @default(uuid())
  userId     String
  matchId    String
  leagueId   String            @default("global")
  homeGuess  Int
  awayGuess  Int
  editCount  Int               @default(0)
  createdAt  DateTime          @default(now())
  processed  Boolean           @default(false)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  match      Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)
  league     League            @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  pointEntry LeaguePointEntry?

  @@unique([userId, matchId, leagueId])
  @@index([userId, leagueId])
  @@index([matchId, leagueId])
  @@index([matchId, processed])
}

model SyncLog {
  id             String   @id @default(uuid())
  syncedAt       DateTime @default(now())
  matchesCreated Int      @default(0)
  matchesUpdated Int      @default(0)
  source         String   @default("worldcup26")

  @@index([syncedAt])
}

model League {
  id                      String                  @id @default(uuid())
  slug                    String?                 @unique
  name                    String
  description             String?
  inviteCode              String                  @unique
  ownerId                 String
  visibility              String                  @default("private")
  joinPolicy              String                  @default("invite")
  status                  String                  @default("active")
  maxMembers              Int                     @default(50)
  scoringPreset           String                  @default("standard")
  scoringStartMatchday    Int                     @default(1)
  groupPublicationMode    String                  @default("match")
  knockoutPublicationMode String                  @default("match")
  rulesLockedAt           DateTime?
  lastPublishedAt         DateTime?
  expiresAt               DateTime
  windowHours             Int                     @default(48)
  maxEdits                Int                     @default(3)
  pointsExact             Int                     @default(5)
  pointsDiff              Int                     @default(3)
  pointsWinner            Int                     @default(2)
  pointsWinnerHome        Int                     @default(2)
  pointsWinnerAway        Int                     @default(2)
  pointsDraw              Int                     @default(2)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @default(now()) @updatedAt
  owner                   User                    @relation("LeagueOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members                 LeagueMember[]
  predictions             Prediction[]
  joinRequests            LeagueJoinRequest[]
  pointEntries            LeaguePointEntry[]
  rankingCycles           LeagueRankingCycle[]
  rankingSnapshots        LeagueRankingSnapshot[]

  @@index([visibility, status, createdAt])
  @@index([ownerId, createdAt])
}

model LeagueMember {
  id            String   @id @default(uuid())
  leagueId      String
  userId        String
  role          String   @default("member")
  points        Int      @default(0)
  pendingPoints Int      @default(0)
  status        String   @default("active")
  joinedAt      DateTime @default(now())
  league        League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId])
  @@index([userId])
  @@index([leagueId, status, points])
}

model LeagueJoinRequest {
  id           String    @id @default(uuid())
  leagueId     String
  userId       String
  status       String    @default("pending")
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  league       League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId])
  @@index([leagueId, status, createdAt])
}

model LeaguePointEntry {
  id           String      @id @default(uuid())
  leagueId     String
  userId       String
  predictionId String?     @unique
  matchId      String?
  points       Int
  status       String      @default("pending")
  kind         String      @default("score")
  stage        String?
  matchday     String?
  cycleKey     String
  publishedAt  DateTime?
  metadata     Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  league       League      @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  prediction   Prediction? @relation(fields: [predictionId], references: [id], onDelete: SetNull)
  match        Match?      @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([leagueId, status, cycleKey])
  @@index([leagueId, userId, status])
  @@index([matchId, leagueId])
}

model LeagueRankingCycle {
  id          String                  @id @default(uuid())
  leagueId    String
  key         String
  status      String                  @default("pending")
  stage       String?
  roundFrom   Int?
  roundTo     Int?
  publishedAt DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  league      League                  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  snapshots   LeagueRankingSnapshot[]

  @@unique([leagueId, key])
  @@index([leagueId, status, createdAt])
}

model LeagueRankingSnapshot {
  id          String             @id @default(uuid())
  leagueId    String
  cycleId     String
  userId      String
  rank        Int
  cyclePoints Int
  totalPoints Int
  createdAt   DateTime           @default(now())
  league      League             @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  cycle       LeagueRankingCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cycleId, userId])
  @@index([leagueId, createdAt])
}

model PasswordResetRequest {
  id                   String   @id @default(uuid())
  userId               String
  proposedPasswordHash String
  status               String   @default("pending")
  reviewedById         String?
  reviewedAt           DateTime?
  reviewNote           String?
  createdAt            DateTime @default(now())
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy           User?    @relation("PasswordResetReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([reviewedById])
}

model MatchLineup {
  id              String   @id @default(uuid())
  matchId         String   @unique
  homeFormation   String   @default("4-3-3")
  awayFormation   String   @default("4-3-3")
  homeStarting    String   @db.Text
  awayStarting    String   @db.Text
  homeSubstitutes String   @db.Text
  awaySubstitutes String   @db.Text
  createdAt       DateTime @default(now())
  match           Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model AdminAuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  summary    String
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AdminAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([entityType, createdAt])
  @@index([actorId, createdAt])
}
